{
  "name": "seytron-vpn",
  "version": "1.0.0",
  "description": "SEYTRONS VPN - Secure & Private Network",
  "main": "index.html",
  "scripts": {
    "build": "npm run copy && npm run sync",
    "copy": "npx cap copy",
    "sync": "npx cap sync",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios",
    "build:android": "npx cap copy && cd android && ./gradlew assembleRelease",
    "build:ios": "npx cap copy && cd ios && xcodebuild"
  },
  "dependencies": {
    "@capacitor/android": "^5.7.8",
    "@capacitor/core": "^5.7.8",
    "@capacitor/ios": "^5.5.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0"
  },
  "directories": {
    "test": "tests"
  },
